<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.minipos.pos.controller.admin.AdminDashboardController"
            styleClass="app-root">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="12"
              prefWidth="260"
              maxWidth="260"
              styleClass="sidebar">

            <padding>
                <Insets top="24" right="18" bottom="24" left="18"/>
            </padding>

            <!-- LOGO -->
            <VBox spacing="4" styleClass="sidebar-header">
                <Label text="Mini-POS" styleClass="sidebar-title neon-text"/>
                <Label text="Admin Panel" styleClass="sidebar-subtitle"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- NAV BUTTONS -->
            <Button text="%nav.dashboard" onAction="#showDashboard" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.history" onAction="#showHistory" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.reports" onAction="#showReports" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.users" onAction="#showUsers" styleClass="nav-button" maxWidth="Infinity"/>
            <Button text="%nav.settings" onAction="#showSettings" styleClass="nav-button" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-separator"/>

            <Button text="%nav.logout"
                    onAction="#handleLogout"
                    styleClass="logout-button"
                    maxWidth="Infinity"/>

        </VBox>
    </left>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentArea"
                   styleClass="main-content"
                   BorderPane.alignment="CENTER">

            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

        </StackPane>
    </center>

</BorderPane>