<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.admin.HistoryController"
      spacing="20"
      styleClass="history-container">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="%history.title" styleClass="history-title"/>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-pane">
        <TextField fx:id="searchField" promptText="%search.placeholder.history" prefWidth="320" styleClass="search-field"/>
        <Button text="%btn.search" onAction="#handleSearch" styleClass="search-button"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="table-container">
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="%col.id" prefWidth="80" minWidth="60"/>
                <TableColumn fx:id="colDate" text="%col.date" prefWidth="180"/>
                <TableColumn fx:id="colTotal" text="%col.total" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="%col.status" prefWidth="130"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>