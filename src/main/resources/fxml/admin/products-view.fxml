<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.minipos.pos.controller.admin.ProductController"
            prefHeight="600.0" prefWidth="1000.0">

    <left>
        <fx:include source="../shared/sidebar.fxml"/>
    </left>

    <center>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f4;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="СПИСОК ТОВАРОВ" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="📥 ИМПОРТ ИЗ EXCEL" onAction="#handleImportExcel"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;"/>
            </HBox>

            <TableView fx:id="productTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
                <columns>
                    <TableColumn fx:id="colName" text="Наименование" prefWidth="250"/>
                    <TableColumn fx:id="colCategory" text="Категория" prefWidth="150"/>
                    <TableColumn fx:id="colPrice" text="Цена" prefWidth="100"/>
                    <TableColumn fx:id="colStock" text="Остаток" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>
</BorderPane>