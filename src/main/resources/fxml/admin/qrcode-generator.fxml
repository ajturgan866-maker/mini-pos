<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="20" style="-fx-padding: 30; -fx-alignment: center;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.admin.QrCodeController">

    <Label text="%qr.title" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <TextField fx:id="dataField" promptText="%qr.prompt" maxWidth="300"/>

    <Button text="%btn.generate" onAction="#handleGenerate" styleClass="btn-action"/>

    <ImageView fx:id="qrImageView" fitWidth="200" fitHeight="200" preserveRatio="true"/>
</VBox>