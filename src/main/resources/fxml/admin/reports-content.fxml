<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.admin.ReportsController"
      spacing="24"
      styleClass="dashboard-container"> <padding>
    <Insets top="30" right="30" bottom="30" left="30"/>
</padding>

    <Label text="%reports.title" styleClass="dashboard-title"/>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="%btn.export.pdf" onAction="#handleExportPdf" styleClass="pdf-button" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 8 15; -fx-font-weight: bold;"/>
        <Button text="%btn.refresh" onAction="#handleRefresh" styleClass="refresh-button" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 15; -fx-font-weight: bold;"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="table-container">
        <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDate" text="%col.date" prefWidth="150"/>
                <TableColumn fx:id="colRevenue" text="%col.revenue" prefWidth="150"/>
                <TableColumn fx:id="colOrdersCount" text="%col.orders.count" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>