<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: #F0F2F5;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.minipos.pos.controller.admin.SalesHistoryController">

    <left>
        <fx:include source="../shared/sidebar.fxml" />
    </left>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <VBox>
                            <children>
                                <Label text="Архив операций" style="-fx-text-fill: #1A202C; -fx-font-weight: 800;">
                                    <font>
                                        <Font size="24.0" />
                                    </font>
                                </Label>
                                <Label text="Управление и просмотр истории всех транзакций" style="-fx-text-fill: #718096;" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />

                        <Button onAction="#initialize"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #2D3748; -fx-background-radius: 8; -fx-cursor: hand;" text="🔄 Обновить">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        </Button>
                        <Button style="-fx-background-color: #3182CE; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(49,130,206,0.3), 10, 0, 0, 4);" text="📥 Экспорт Excel">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                        </Button>
                    </children>
                </HBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <TableView fx:id="salesTable"
                                   style="-fx-background-color: white; -fx-background-insets: 0; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;"
                                   VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="80.0" minWidth="60.0" text="№" />
                                <TableColumn fx:id="colDate" prefWidth="180.0" text="Дата и Время" />
                                <TableColumn fx:id="colCashier" prefWidth="150.0" text="Кассир" />
                                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Итоговая сумма" />
                                <TableColumn fx:id="colItems" prefWidth="400.0" text="Состав продажи" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>