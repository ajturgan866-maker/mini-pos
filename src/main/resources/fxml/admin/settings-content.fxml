<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.admin.SettingsController"
      spacing="24"
      styleClass="settings-container">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="%settings.title" styleClass="settings-title"/>

    <VBox spacing="12" styleClass="settings-card">
        <Label text="%settings.lang" styleClass="settings-section-title"/>
        <HBox spacing="12">
            <Button text="%lang.ru" onAction="#changeToRussian" styleClass="settings-button"/>
            <Button text="%lang.en" onAction="#changeToEnglish" styleClass="settings-button"/>
        </HBox>
    </VBox>

    <VBox spacing="12" styleClass="settings-card">
        <Label text="%settings.theme" styleClass="settings-section-title"/>
        <HBox spacing="12">
            <Button text="%theme.light" onAction="#setToLightTheme" styleClass="settings-button"/>
            <Button text="%theme.dark" onAction="#setToDarkTheme" styleClass="settings-button"/>
        </HBox>
    </VBox>
</VBox>