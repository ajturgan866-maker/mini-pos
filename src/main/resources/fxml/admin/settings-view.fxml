<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.minipos.pos.controller.admin.SettingsController"
            style="-fx-background-color: #F0F2F5;">

    <center>

        <VBox spacing="20"
              alignment="TOP_LEFT"
              style="-fx-padding: 30;">

            <!-- HEADER -->
            <Label text="Настройки системы"
                   style="-fx-font-size: 24;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1A202C;"/>

            <!-- CARD -->
            <VBox spacing="15"
                  style="-fx-background-color: white;
                         -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">

                <CheckBox text="Тёмная тема (в разработке)"
                          style="-fx-font-size: 14;"/>

                <Separator/>

                <Label text="Опасная зона"
                       style="-fx-font-weight: bold;
                              -fx-text-fill: #DC3545;"/>

                <Button text="Очистить базу данных (DDL Create)"
                        style="-fx-background-color: #DC3545;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-background-radius: 8;"/>

            </VBox>

        </VBox>

    </center>

</BorderPane>