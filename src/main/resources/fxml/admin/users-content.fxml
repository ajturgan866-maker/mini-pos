<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.admin.UsersController"
      spacing="24"
      styleClass="users-container">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="users-header">

        <Label text="Управление персоналом"
               styleClass="users-title"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="+ Добавить оператора"
                onAction="#handleAddUser"
                styleClass="add-user-button"/>

    </HBox>

    <!-- TABLE -->
    <VBox VBox.vgrow="ALWAYS" styleClass="table-container">

        <TableView fx:id="usersTable"
                   VBox.vgrow="ALWAYS"
                   styleClass="table-view users-table">

            <columns>

                <TableColumn fx:id="colUsername"
                             text="Логин"
                             prefWidth="180"/>

                <TableColumn fx:id="colRole"
                             text="Роль"
                             prefWidth="130"/>

                <TableColumn fx:id="colPassword"
                             text="Пароль (hash)"
                             prefWidth="250"/>

            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

        </TableView>

    </VBox>

</VBox>