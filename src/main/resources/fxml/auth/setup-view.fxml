<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.minipos.pos.controller.auth.SetupController"
           style="-fx-background-color: #064e3b;">

    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <HBox alignment="CENTER" maxWidth="900" maxHeight="620"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 10);">

        <VBox alignment="CENTER" spacing="20" prefWidth="350"
              style="-fx-background-color: #064e3b; -fx-background-radius: 16 0 0 16; -fx-padding: 40;">
            <Circle radius="40" fill="#22c55e"/>
            <Label text="Mini-POS" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="%setup.sidebar.subtitle" style="-fx-font-size: 16; -fx-text-fill: #a7f3d0;"/>
            <Separator prefWidth="180" style="-fx-background-color: #ffffff; -fx-opacity: 0.2;"/>
            <Text text="%setup.sidebar.desc" wrappingWidth="250" textAlignment="CENTER"
                  style="-fx-fill: #d1fae5; -fx-font-size: 14;"/>
        </VBox>

        <VBox spacing="15" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
              style="-fx-padding: 40; -fx-background-color: white; -fx-background-radius: 0 16 16 0;">

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button text="RU" onAction="#changeToRussian" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-padding: 5 15; -fx-cursor: hand;"/>
                <Button text="EN" onAction="#changeToEnglish" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-font-weight: bold; -fx-padding: 5 15; -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="10">
                <Label text="%setup.field.user" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="usernameField" style="-fx-text-fill: #1e293b; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-padding: 10;"/>

                <Label text="%setup.field.password" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <StackPane alignment="CENTER_RIGHT">
                    <PasswordField fx:id="passwordField" style="-fx-text-fill: #1e293b; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-padding: 10 40 10 10;"/>
                    <TextField fx:id="passwordVisibleField" visible="false" style="-fx-text-fill: #1e293b; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-padding: 10 40 10 10;"/>
                    <Button text="👁" onMousePressed="#showPassword" onMouseReleased="#hidePassword" style="-fx-background-color: transparent; -fx-cursor: hand;"/>
                </StackPane>

                <Label text="%setup.field.confirm" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <StackPane alignment="CENTER_RIGHT">
                    <PasswordField fx:id="confirmPasswordField" style="-fx-text-fill: #1e293b; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-padding: 10 40 10 10;"/>
                    <TextField fx:id="confirmVisibleField" visible="false" style="-fx-text-fill: #1e293b; -fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-padding: 10 40 10 10;"/>
                </StackPane>

                <Label fx:id="errorLabel" text="Error" visible="false" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;"/>

                <Button text="%setup.button.submit" onAction="#handleSetup" maxWidth="Infinity"
                        style="-fx-background-color: #064e3b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>