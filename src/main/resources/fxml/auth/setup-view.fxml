<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.minipos.pos.controller.auth.SetupController"
           style="-fx-background-color: linear-gradient(to bottom right, #064e3b, #111827);">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <HBox alignment="CENTER"
          maxWidth="900"
          maxHeight="550"
          HBox.hgrow="ALWAYS"
          VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 40, 0, 0, 20);">

        <VBox alignment="CENTER"
              spacing="20"
              prefWidth="350"
              style="-fx-background-color: #064e3b; -fx-background-radius: 16 0 0 16; -fx-padding: 40;"
              VBox.vgrow="ALWAYS">

            <Circle radius="30" fill="#22c55e"/>

            <Label text="Mini-POS System"
                   style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Label text="Первоначальная настройка"
                   style="-fx-font-size: 14; -fx-text-fill: #a7f3d0;"/>

            <Separator prefWidth="180" style="-fx-opacity: 0.2; -fx-padding: 10 0;"/>

            <Label text="Для начала работы создайте учетную запись главного администратора (владельца)."
                   wrapText="true"
                   alignment="CENTER"
                   style="-fx-text-fill: #d1fae5; -fx-font-size: 13; -fx-text-alignment: center; -fx-line-spacing: 4;"/>
        </VBox>

        <VBox spacing="25"
              alignment="CENTER_LEFT"
              HBox.hgrow="ALWAYS"
              style="-fx-padding: 50; -fx-background-color: white; -fx-background-radius: 0 16 16 0;">

            <VBox spacing="6">
                <Label text="Создание владельца"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Label text="Заполните параметры администратора для доступа к панели"
                       style="-fx-font-size: 13; -fx-text-fill: #6b7280;"/>
            </VBox>

            <VBox spacing="14" maxWidth="Infinity">
                <VBox spacing="6">
                    <Label text="Логин администратора" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="usernameField"
                               promptText="Введите имя пользователя (напр. admin)"
                               style="-fx-background-radius: 8; -fx-padding: 12; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-color: #f8fafc; -fx-font-size: 13;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Пароль" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Минимум 6 символов"
                                   style="-fx-background-radius: 8; -fx-padding: 12; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-color: #f8fafc; -fx-font-size: 13;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Подтверждение пароля" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Повторите введенный пароль"
                                   style="-fx-background-radius: 8; -fx-padding: 12; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-background-color: #f8fafc; -fx-font-size: 13;"/>
                </VBox>
            </VBox>

            <VBox spacing="12" alignment="CENTER" maxWidth="Infinity">
                <Button text="СОЗДАТЬ И ПЕРЕЙТИ В АДМИНКУ"
                        onAction="#handleSetup"
                        maxWidth="Infinity"
                        prefHeight="48"
                        style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-font-size: 14; -fx-cursor: hand;"/>

                <Label fx:id="errorLabel"
                       visible="false"
                       style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 13;"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>