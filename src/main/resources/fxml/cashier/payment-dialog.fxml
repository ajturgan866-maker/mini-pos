<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.PaymentDialogController"
      spacing="15"
      alignment="TOP_CENTER"
      prefWidth="420"
      style="-fx-background-color: white;
             -fx-background-radius: 12;
             -fx-border-color: #E2E8F0;
             -fx-border-radius: 12;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- TITLE -->
    <Label text="Приём оплаты">
        <font>
            <Font size="22"/>
        </font>
        <style>
            -fx-font-weight: bold;
            -fx-text-fill: #1A202C;
        </style>
    </Label>

    <!-- TOTAL CARD -->
    <VBox spacing="5"
          style="-fx-background-color: #F8F9FA;
                 -fx-padding: 15;
                 -fx-background-radius: 10;
                 -fx-border-color: #E2E8F0;
                 -fx-border-radius: 10;">

        <Label text="К оплате:" style="-fx-text-fill: #718096;"/>

        <Label fx:id="totalAmountLabel"
               text="0.00 руб.">
            <font>
                <Font size="22"/>
            </font>
            <style>
                -fx-font-weight: bold;
                -fx-text-fill: #DC3545;
            </style>
        </Label>

    </VBox>

    <!-- INPUT -->
    <VBox spacing="8">

        <Label text="Получено от клиента:"
               style="-fx-text-fill: #4A5568;"/>

        <TextField fx:id="cashReceivedField"
                   onKeyReleased="#calculateChange"
                   promptText="0.00"
                   prefHeight="45"
                   style="-fx-font-size: 18;
                          -fx-background-radius: 8;
                          -fx-border-color: #CBD5E0;
                          -fx-border-radius: 8;"/>

    </VBox>

    <!-- CHANGE -->
    <HBox spacing="10" alignment="CENTER_LEFT">

        <Label text="Сдача:"
               style="-fx-text-fill: #718096;"/>

        <Label fx:id="changeLabel"
               text="0.00 руб.">
            <font>
                <Font size="22"/>
            </font>
            <style>
                -fx-font-weight: bold;
                -fx-text-fill: #28A745;
            </style>
        </Label>

    </HBox>

    <!-- BUTTONS -->
    <HBox spacing="10" alignment="CENTER">

        <Button text="ОТМЕНА"
                onAction="#handleCancel"
                prefWidth="160"
                style="-fx-background-color: #E2E8F0;
                       -fx-text-fill: #2D3748;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>

        <Button text="ПОДТВЕРДИТЬ"
                onAction="#handleConfirm"
                prefWidth="160"
                style="-fx-background-color: #28A745;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>

    </HBox>

</VBox>