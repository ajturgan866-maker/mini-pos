<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.minipos.pos.controller.cashier.ReceiptController"
      spacing="12"
      prefWidth="350"
      style="-fx-background-color: white;
             -fx-background-radius: 12;
             -fx-border-color: #E2E8F0;
             -fx-border-radius: 12;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- HEADER -->
    <Label text="ЧЕК ПРОДАЖИ"
           style="-fx-font-size: 18;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1A202C;"/>

    <Separator/>

    <!-- INFO BLOCK -->
    <VBox spacing="6">

        <Label fx:id="saleIdLabel"
               style="-fx-text-fill: #4A5568;"/>

        <Label fx:id="totalLabel"
               style="-fx-text-fill: #2D3748;
                      -fx-font-weight: bold;"/>

        <Label fx:id="paymentTypeLabel"
               style="-fx-text-fill: #718096;"/>

    </VBox>

    <Separator/>

    <!-- ITEMS -->
    <Label text="Состав покупки:"
           style="-fx-font-weight: bold;
                  -fx-text-fill: #2D3748;"/>

    <TextArea fx:id="itemsArea"
              editable="false"
              wrapText="true"
              prefHeight="200"
              style="-fx-background-color: #F8F9FA;
                     -fx-border-color: #E2E8F0;
                     -fx-border-radius: 8;"/>

    <!-- BUTTON -->
    <Button text="Закрыть"
            onAction="#close"
            maxWidth="Infinity"
            style="-fx-background-color: #3182CE;
                   -fx-text-fill: white;
                   -fx-font-weight: bold;
                   -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

</VBox>