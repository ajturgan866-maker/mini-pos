<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f1f5f9; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.cashier.ReceiptViewController">
    <children>

        <Label text="Электронный чек" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />

        <TextArea fx:id="receiptTextArea" editable="false" prefHeight="420.0" prefWidth="320.0"
                  style="-fx-font-family: 'Monospaced'; -fx-font-size: 13px; -fx-control-inner-background: #ffffff; -fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 4;" />

        <Button mnemonicParsing="false" onAction="#handlePrint" prefHeight="40.0" prefWidth="320.0"
                text="ПЕЧАТЬ И ЗАКРЫТЬ"
                style="-fx-background-color: #2f6fed; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />

    </children>
</VBox>