<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.minipos.pos.controller.client.ClientMenuController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 20 0 20;">
            <children>
                <Label fx:id="titleLabel" text="%menu.title" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />

                <HBox HBox.hgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#changeToRussian" text="RU" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button mnemonicParsing="false" onAction="#changeToEnglish" text="EN" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;"/>

                <Button mnemonicParsing="false" onAction="#toggleTheme" text="🌗" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14px;"/>
            </children>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 15;" BorderPane.alignment="CENTER">
            <content>
                <GridPane fx:id="menuGrid" hgap="20.0" vgap="20.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </GridPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>