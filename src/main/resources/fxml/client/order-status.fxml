<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.minipos.pos.controller.client.OrderStatusController"
           style="-fx-background-color: #0f172a;"> <VBox alignment="CENTER" spacing="40" style="-fx-padding: 50;">

    <Label fx:id="titleLabel" text="%status.order.title"
           style="-fx-text-fill: #94a3b8; -fx-font-size: 24;"/>

    <Label fx:id="orderNumberLabel" text="Заказ #000"
           style="-fx-text-fill: white; -fx-font-size: 80; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" style="-fx-background-color: #1e293b; -fx-background-radius: 20; -fx-padding: 20 40;">
        <Label fx:id="statusLabel" text="---"
               style="-fx-text-fill: #22c55e; -fx-font-size: 40; -fx-font-weight: bold;"/>
    </HBox>

</VBox>

</StackPane>