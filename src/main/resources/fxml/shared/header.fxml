<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox alignment="CENTER_LEFT" spacing="20" prefHeight="50"
      style="-fx-background-color: #2c3e50; -fx-padding: 0 20 0 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.HeaderController">

    <Label text="Mini-POS" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>

    <Region HBox.hgrow="ALWAYS" /> <HBox alignment="CENTER" spacing="10">
    <Label fx:id="usernameLabel" text="Имя Пользователя" style="-fx-text-fill: white;"/>
    <Label fx:id="roleLabel" text="[Роль]" style="-fx-text-fill: #bdc3c7; -fx-font-size: 12;"/>
</HBox>

    <Label fx:id="dateTimeLabel" text="01.01.2026 12:00" style="-fx-text-fill: white;"/>

    <Button text="Выход" onAction="#handleLogout"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
</HBox>