<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="260"
      minWidth="260"
      maxWidth="260"
      spacing="6"
      styleClass="sidebar"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minipos.pos.controller.shared.SidebarController"
      stylesheets="@../../css/main.css">

    <padding>
        <Insets top="20" right="12" bottom="20" left="12"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding: 0 0 20 10;">
        <ImageView fitHeight="28" fitWidth="28" preserveRatio="true">
            <Image url="@../../icons/dashboard.png"/>
        </ImageView>

        <Label text="MINI POS"
               style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #1976D2;"/>
    </HBox>

    <!-- MENU -->
    <VBox spacing="6" VBox.vgrow="ALWAYS">

        <Button fx:id="btnDashboard" text="Панель управления"
                onAction="#showDashboard"
                maxWidth="Infinity" />

        <Button fx:id="btnUsers" text="Пользователи"
                onAction="#showUsers"
                maxWidth="Infinity" />

        <Button fx:id="btnProducts" text="Товары"
                onAction="#showProducts"
                maxWidth="Infinity" />

        <Button fx:id="btnCategories" text="Категории"
                onAction="#showCategories"
                maxWidth="Infinity" />

        <Button fx:id="btnSales" text="История продаж"
                onAction="#showSales"
                maxWidth="Infinity" />

    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- BOTTOM -->
    <VBox spacing="6">

        <Button fx:id="btnSettings" text="Настройки"
                onAction="#showSettings"
                maxWidth="Infinity" />

        <Button text="Выйти"
                onAction="#handleLogout"
                maxWidth="Infinity"
                style="-fx-text-fill: #E74C3C;"/>
    </VBox>

</VBox>